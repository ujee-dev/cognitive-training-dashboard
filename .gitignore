# --- [ 1. 공통 및 OS/IDE 무시 ] ---
.DS_Store
Thumbs.db
*.log
.idea/
*.sw?
*.pem
.env
.env.*
*.local
*.sublime-workspace

.vscode/
# vscode 내에서 Git에 포함되어야 하는 파일을 제외(ignore)에서 제외(!) 시킵니다.
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- [ 2. 빌드 결과물 (모든 스택 공통) ] ---
**/node_modules/
**/dist/
**/build/
**/out/
**/bin/
**/.gradle/

# --- [ 3. 클라이언트 (Frontend) ] ---
client/dist-ssr/
client/coverage/
client/test-results/
client/playwright-report/
client/stats.html
client/src/pages/ForbiddenPage.tsx

# --- [ 4. Nest 서버 (backend-nest) ] ---
backend-nest/uploads/
backend-nest/coverage/
backend-nest/src/test/
# DB 및 런타임 데이터
backend-nest/*.db
backend-nest/*.sqlite
backend-nest/pids
backend-nest/*.pid
backend-nest/*.seed
backend-nest/*.pid.lock


# --- [ 5. Spring 서버 (backend-spring) ] ---
**/*.iml
backend-spring/uploads/
# Spring 환경별 설정 파일 중 로컬/비밀 정보
**/application-local.yml
**/application-secret.yml
**/application-*-local.yml
# Gradle Wrapper는 Git에 포함되어야 하므로 제외(ignore)에서 제외(!) 시킵니다.
!**/gradle/wrapper/gradle-wrapper.jar

# --- [ 6.1 기타 임시 파일 ] ---
**/.temp/
**/.tmp/
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# --- [ 6.2 기타 로그 및 테스트 ] ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/.nyc_output
/coverage

# --- [ 6.3 기타 운영체제 및 범용 에디터 ] ---
.project
.settings/
*.sln
*.suo
*.ntvs*
*.njsproj
